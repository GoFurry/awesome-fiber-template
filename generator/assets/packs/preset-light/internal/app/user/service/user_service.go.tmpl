package service

import (
	"context"
	"errors"
	"strings"

	"{{module_path}}/internal/app/user/dao"
	"{{module_path}}/internal/app/user/models"
	appdb "{{module_path}}/internal/infra/db"
)

var ErrInvalidUserInput = errors.New("invalid user input")

var userService *Service

type Service struct {
	store *dao.Store
}

func Init(database *appdb.Handle) {
	userService = &Service{store: dao.NewStore(database)}
}

func GetUserService() *Service {
	return userService
}

func (s *Service) Create(ctx context.Context, input models.CreateUserInput) (models.User, error) {
	if err := validateCreate(input); err != nil {
		return models.User{}, err
	}
	return s.store.Create(ctx, input)
}

func (s *Service) List(ctx context.Context, pageNum, pageSize int) (models.UserList, error) {
	if pageNum <= 0 {
		pageNum = 1
	}
	if pageSize <= 0 {
		pageSize = 10
	}
	if pageSize > 100 {
		pageSize = 100
	}

	return s.store.List(ctx, (pageNum-1)*pageSize, pageSize)
}

func (s *Service) Get(ctx context.Context, id int64) (models.User, error) {
	return s.store.Get(ctx, id)
}

func (s *Service) Update(ctx context.Context, id int64, input models.UpdateUserInput) (models.User, error) {
	if err := validateUpdate(input); err != nil {
		return models.User{}, err
	}
	return s.store.Update(ctx, id, input)
}

func (s *Service) Delete(ctx context.Context, id int64) error {
	return s.store.Delete(ctx, id)
}

func validateCreate(input models.CreateUserInput) error {
	if strings.TrimSpace(input.Name) == "" || strings.TrimSpace(input.Email) == "" || input.Age <= 0 {
		return ErrInvalidUserInput
	}
	if strings.TrimSpace(input.Status) == "" {
		return ErrInvalidUserInput
	}
	return nil
}

func validateUpdate(input models.UpdateUserInput) error {
	if strings.TrimSpace(input.Name) == "" || strings.TrimSpace(input.Email) == "" || input.Age <= 0 {
		return ErrInvalidUserInput
	}
	if strings.TrimSpace(input.Status) == "" {
		return ErrInvalidUserInput
	}
	return nil
}
