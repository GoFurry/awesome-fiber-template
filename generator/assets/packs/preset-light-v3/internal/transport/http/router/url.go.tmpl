package router

import (
	user "{{module_path}}/internal/app/user/controller"
	"github.com/gofiber/fiber/v3"
)

func api(root fiber.Router) {
	v1(root.Group("/v1"))
}

func v1(root fiber.Router) {
	userRoutes(root.Group("/user"))
}

func userRoutes(root fiber.Router) {
	root.Post("/", user.UserAPI.Create)
	root.Get("/", user.UserAPI.List)
	root.Get("/:id", user.UserAPI.Get)
	root.Put("/:id", user.UserAPI.Update)
	root.Delete("/:id", user.UserAPI.Delete)
}
