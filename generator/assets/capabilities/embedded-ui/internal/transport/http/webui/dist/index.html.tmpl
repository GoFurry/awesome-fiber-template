<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{project_name}} UI</title>
  <style>
    body { font-family: ui-sans-serif, system-ui, sans-serif; margin: 0; background: #0f172a; color: #e2e8f0; }
    main { max-width: 720px; margin: 0 auto; padding: 64px 24px; }
    h1 { margin-bottom: 8px; font-size: 40px; }
    p { color: #cbd5e1; line-height: 1.6; }
    code { background: rgba(148, 163, 184, 0.15); padding: 2px 6px; border-radius: 6px; }
  </style>
</head>
<body>
  <main>
    <h1>{{project_name}}</h1>
    <p>This embedded UI ships with the <code>medium</code> production baseline.</p>
    <p>Module: <code>{{module_path}}</code></p>
  </main>
</body>
</html>
